{% doc %}
  @prompt
    marquee
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
    position: relative;
  }

  .ai-marquee-track-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-marquee-content-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.item_spacing }}px;
    flex-shrink: 0;
  }

  .ai-marquee-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.item_spacing }}px;
    white-space: nowrap;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    {% if block.settings.text_transform %}
      text-transform: uppercase;
    {% endif %}
  }

  .ai-marquee-separator-{{ ai_gen_id }} {
    color: {{ block.settings.separator_color }};
    font-size: {{ block.settings.font_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-marquee-item-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.8);
    }

    .ai-marquee-separator-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.8);
    }
  }
{% endstyle %}

<marquee-scroller-{{ ai_gen_id }}
  class="ai-marquee-{{ ai_gen_id }}"
  data-speed="{{ block.settings.scroll_speed }}"
  data-direction="{{ block.settings.direction }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-marquee-track-{{ ai_gen_id }}">
    <div class="ai-marquee-content-{{ ai_gen_id }}">
      {% if block.settings.text_1 != blank %}
        <div class="ai-marquee-item-{{ ai_gen_id }}">{{ block.settings.text_1 }}</div>
        <span class="ai-marquee-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
      {% endif %}
      {% if block.settings.text_2 != blank %}
        <div class="ai-marquee-item-{{ ai_gen_id }}">{{ block.settings.text_2 }}</div>
        <span class="ai-marquee-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
      {% endif %}
      {% if block.settings.text_3 != blank %}
        <div class="ai-marquee-item-{{ ai_gen_id }}">{{ block.settings.text_3 }}</div>
        <span class="ai-marquee-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
      {% endif %}
      {% if block.settings.text_4 != blank %}
        <div class="ai-marquee-item-{{ ai_gen_id }}">{{ block.settings.text_4 }}</div>
        <span class="ai-marquee-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
      {% endif %}
      {% if block.settings.text_5 != blank %}
        <div class="ai-marquee-item-{{ ai_gen_id }}">{{ block.settings.text_5 }}</div>
        <span class="ai-marquee-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
      {% endif %}
    </div>
  </div>
</marquee-scroller-{{ ai_gen_id }}>

<script>
  (function() {
    class MarqueeScroller{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = null;
        this.content = null;
        this.animationId = null;
        this.position = 0;
        this.speed = 1;
        this.direction = 'left';
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-marquee-track-{{ ai_gen_id }}');
        this.content = this.querySelector('.ai-marquee-content-{{ ai_gen_id }}');
        
        if (!this.track || !this.content) return;

        this.speed = parseFloat(this.dataset.speed) || 1;
        this.direction = this.dataset.direction || 'left';

        this.duplicateContent();
        this.startAnimation();

        this.addEventListener('mouseenter', () => this.pauseAnimation());
        this.addEventListener('mouseleave', () => this.startAnimation());
      }

      duplicateContent() {
        const contentWidth = this.content.offsetWidth;
        const viewportWidth = this.offsetWidth;
        const duplicatesNeeded = Math.ceil(viewportWidth / contentWidth) + 2;

        for (let i = 0; i < duplicatesNeeded; i++) {
          const clone = this.content.cloneNode(true);
          this.track.appendChild(clone);
        }
      }

      startAnimation() {
        if (this.animationId) return;

        const animate = () => {
          const contentWidth = this.content.offsetWidth;
          
          if (this.direction === 'left') {
            this.position -= this.speed;
            if (Math.abs(this.position) >= contentWidth) {
              this.position = 0;
            }
          } else {
            this.position += this.speed;
            if (this.position >= contentWidth) {
              this.position = 0;
            }
          }

          this.track.style.transform = `translateX(${this.position}px)`;
          this.animationId = requestAnimationFrame(animate);
        };

        this.animationId = requestAnimationFrame(animate);
      }

      pauseAnimation() {
        if (this.animationId) {
          cancelAnimationFrame(this.animationId);
          this.animationId = null;
        }
      }

      disconnectedCallback() {
        this.pauseAnimation();
      }
    }

    customElements.define('marquee-scroller-{{ ai_gen_id }}', MarqueeScroller{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Text 1",
      "default": "Free shipping on orders over $50"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Text 2",
      "default": "New arrivals every week"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Text 3",
      "default": "Shop the latest trends"
    },
    {
      "type": "text",
      "id": "text_4",
      "label": "Text 4"
    },
    {
      "type": "text",
      "id": "text_5",
      "label": "Text 5"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "★"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "min": 0.5,
      "max": 5,
      "step": 0.5,
      "default": 1
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "checkbox",
      "id": "text_transform",
      "label": "Uppercase text",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Item spacing",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Marquee"
    }
  ]
}
{% endschema %}
