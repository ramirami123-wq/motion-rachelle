{% doc %}
  @prompt
    i want a benefits table us vs others 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-table-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-comparison-table__wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
    overflow-x: auto;
  }

  .ai-comparison-table__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-comparison-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
  }

  .ai-comparison-table__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_background }};
  }

  .ai-comparison-table__header-cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    font-weight: 600;
    color: {{ block.settings.header_text_color }};
    font-size: {{ block.settings.header_font_size }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__header-cell-{{ ai_gen_id }}:first-child {
    text-align: left;
  }

  .ai-comparison-table__us-header-{{ ai_gen_id }} {
    background-color: {{ block.settings.us_column_background }};
    color: {{ block.settings.us_column_text_color }};
  }

  .ai-comparison-table__row-{{ ai_gen_id }} {
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-comparison-table__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: center;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-comparison-table__cell-{{ ai_gen_id }}:first-child {
    text-align: left;
    font-weight: 500;
  }

  .ai-comparison-table__us-cell-{{ ai_gen_id }} {
    background-color: {{ block.settings.us_cell_background }};
  }

  .ai-comparison-table__icon-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
  }

  .ai-comparison-table__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-comparison-table__checkmark-{{ ai_gen_id }} {
    color: {{ block.settings.checkmark_color }};
  }

  .ai-comparison-table__cross-{{ ai_gen_id }} {
    color: {{ block.settings.cross_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-table__wrapper-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.6 }}px;
    }

    .ai-comparison-table__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
      margin-bottom: {{ block.settings.heading_spacing | times: 0.7 }}px;
    }

    .ai-comparison-table__header-cell-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_font_size | times: 0.85 }}px;
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }

    .ai-comparison-table__cell-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.85 }}px;
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }

    .ai-comparison-table__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<comparison-table-{{ ai_gen_id }} class="ai-comparison-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-comparison-table__wrapper-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-comparison-table__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <table class="ai-comparison-table__table-{{ ai_gen_id }}">
      <thead class="ai-comparison-table__header-{{ ai_gen_id }}">
        <tr>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }}">{{ block.settings.feature_column_label }}</th>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }} ai-comparison-table__us-header-{{ ai_gen_id }}">{{ block.settings.us_column_label }}</th>
          <th class="ai-comparison-table__header-cell-{{ ai_gen_id }}">{{ block.settings.others_column_label }}</th>
        </tr>
      </thead>
      <tbody>
        {% for i in (1..8) %}
          {% assign feature_key = 'feature_' | append: i %}
          {% assign us_key = 'feature_' | append: i | append: '_us' %}
          {% assign others_key = 'feature_' | append: i | append: '_others' %}
          
          {% assign feature_text = block.settings[feature_key] %}
          {% assign us_value = block.settings[us_key] %}
          {% assign others_value = block.settings[others_key] %}
          
          {% if feature_text != blank %}
            <tr class="ai-comparison-table__row-{{ ai_gen_id }}">
              <td class="ai-comparison-table__cell-{{ ai_gen_id }}">{{ feature_text }}</td>
              <td class="ai-comparison-table__cell-{{ ai_gen_id }} ai-comparison-table__us-cell-{{ ai_gen_id }}">
                {% if us_value == 'check' %}
                  <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__checkmark-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>
                {% elsif us_value == 'cross' %}
                  <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__cross-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                {% endif %}
              </td>
              <td class="ai-comparison-table__cell-{{ ai_gen_id }}">
                {% if others_value == 'check' %}
                  <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__checkmark-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>
                {% elsif others_value == 'cross' %}
                  <span class="ai-comparison-table__icon-{{ ai_gen_id }} ai-comparison-table__cross-{{ ai_gen_id }}">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                {% endif %}
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</comparison-table-{{ ai_gen_id }}>

